# NSE Options Bot Configuration
# Copy this file to .env and fill in your credentials

# Mode: "paper" or "live"
BOT_MODE=paper

# Kite Connect API (for nse_options_bot)
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=  # Generated daily after login

# IndMoney API (read-only, for cross-validation)
INDMONEY_BEARER_TOKEN=your_indmoney_token

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Database
DATABASE_URL=sqlite+aiosqlite:///./nse_bot.db
# For production: postgresql+asyncpg://user:pass@host:5432/nse_bot

# Redis (for caching tick data)
REDIS_URL=redis://localhost:6379/0

# Risk Parameters
MAX_CAPITAL=500000
MAX_LOSS_PER_TRADE=10000
MAX_DAILY_LOSS=25000
MAX_POSITION_SIZE_PCT=0.20
INTRADAY_LOSS_LIMIT=15000

# Paper Trading Settings
PAPER_INITIAL_CAPITAL=500000
PAPER_BROKERAGE_PER_ORDER=20
PAPER_STT_RATE=0.000625

# Trading Parameters
DEFAULT_PRODUCT=NRML
PREFER_MIS_FOR_EXPIRY_DAY=true
SL_BUFFER_PCT=0.30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# NSE ADVISOR SETTINGS (for nse_advisor/)
# =============================================================================

# Capital (INR)
PAPER_CAPITAL=500000
ACTUAL_CAPITAL=0

# Primary instruments
PRIMARY_UNDERLYING=NIFTY
SECONDARY_UNDERLYING=BANKNIFTY

# Timing (seconds)
SCAN_INTERVAL_SECONDS=60
CHAIN_STALE_SECONDS=10
NSE_SESSION_REFRESH_MINUTES=25

# Options math (update quarterly)
RFR_RATE=0.068
NIFTY_DIV_YIELD=0.012
BANKNIFTY_DIV_YIELD=0.0

# Risk thresholds
MAX_LOSS_PER_TRADE_INR=3000
MAX_OPEN_TRADES=3
MAX_LOTS_PER_TRADE_NIFTY=10
MAX_LOTS_PER_TRADE_BANKNIFTY=8
KELLY_FRACTION=0.5
MAX_UNDEFINED_RISK_PCT=0.10

# Signal thresholds
MIN_COMPOSITE_SCORE=0.45
MIN_CONFIDENCE=0.60
MIN_IVR_FOR_SELLING=50.0
MAX_IVR_FOR_BUYING=35.0
MIN_OI_LOTS=500

# Exit thresholds
TAKE_PROFIT_PCT_OF_MAX_PROFIT=0.75
STOP_LOSS_PCT_OF_MAX_LOSS=1.5
THETA_BURN_LIMIT_INR_PER_DAY=2000
DELTA_HEDGE_THRESHOLD=0.30
VEGA_THRESHOLD=500.0

# Market timing (IST)
NO_NEW_SIGNALS_AFTER=15:00
TIMEZONE=Asia/Kolkata
