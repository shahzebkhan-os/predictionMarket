# NSE Options Bot Configuration
# Copy this file to .env and fill in your credentials

# Mode: "paper" or "live"
BOT_MODE=paper

# Kite Connect API
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=  # Generated daily after login

# IndMoney API (read-only, for cross-validation)
INDMONEY_BEARER_TOKEN=your_indmoney_token

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Database
DATABASE_URL=sqlite+aiosqlite:///./nse_bot.db
# For production: postgresql+asyncpg://user:pass@host:5432/nse_bot

# Redis (for caching tick data)
REDIS_URL=redis://localhost:6379/0

# Risk Parameters
MAX_CAPITAL=500000
MAX_LOSS_PER_TRADE=10000
MAX_DAILY_LOSS=25000
MAX_POSITION_SIZE_PCT=0.20
INTRADAY_LOSS_LIMIT=15000

# Paper Trading Settings
PAPER_INITIAL_CAPITAL=500000
PAPER_BROKERAGE_PER_ORDER=20
PAPER_STT_RATE=0.000625

# Trading Parameters
DEFAULT_PRODUCT=NRML
PREFER_MIS_FOR_EXPIRY_DAY=true
SL_BUFFER_PCT=0.30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
