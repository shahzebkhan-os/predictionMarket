# NSE Options Signal Advisor Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# NSE ADVISOR SETTINGS
# =============================================================================

# Paper Trading Mode
PAPER_TRADING=true

# IndMoney API (read-only, for cross-validation)
INDMONEY_BEARER_TOKEN=your_indmoney_token

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Database
DATABASE_URL=sqlite+aiosqlite:///./nse_advisor.db
# For production: postgresql+asyncpg://user:pass@host:5432/nse_advisor

# Redis (for caching tick data)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CAPITAL & RISK PARAMETERS
# =============================================================================

# Capital (INR)
PAPER_CAPITAL=500000
ACTUAL_CAPITAL=0

# Risk thresholds
MAX_LOSS_PER_TRADE_INR=3000
MAX_OPEN_TRADES=3
MAX_LOTS_PER_TRADE_NIFTY=10
MAX_LOTS_PER_TRADE_BANKNIFTY=8
KELLY_FRACTION=0.5
MAX_UNDEFINED_RISK_PCT=0.10

# =============================================================================
# PRIMARY INSTRUMENTS & TIMING
# =============================================================================

# Primary instruments
PRIMARY_UNDERLYING=NIFTY
SECONDARY_UNDERLYING=BANKNIFTY

# Timing (seconds)
SCAN_INTERVAL_SECONDS=60
CHAIN_STALE_SECONDS=10
NSE_SESSION_REFRESH_MINUTES=25
TICKER_STALE_SECONDS=15
CIRCUIT_BREAKER_FLAT_MINUTES=3

# NSE Session (anti-bot handling)
NSE_MAX_RETRIES=3
NSE_RATE_LIMIT_BACKOFF_SECONDS=60
NSE_IP_BAN_BACKOFF_SECONDS=3600
NSE_HEALTH_CHECK_INTERVAL_SECONDS=300
USE_PLAYWRIGHT_FALLBACK=false

# Market timing (IST)
NO_NEW_SIGNALS_AFTER=15:00
TIMEZONE=Asia/Kolkata

# =============================================================================
# OPTIONS MATH (update quarterly)
# =============================================================================

# Risk-free rate (India 91-day T-bill rate, ~6.8%)
RFR_RATE=0.068

# Dividend yields
NIFTY_DIV_YIELD=0.012
BANKNIFTY_DIV_YIELD=0.0

# =============================================================================
# SIGNAL THRESHOLDS
# =============================================================================

MIN_COMPOSITE_SCORE=0.45
MIN_CONFIDENCE=0.60
MIN_IVR_FOR_SELLING=50.0
MAX_IVR_FOR_BUYING=35.0
MIN_OI_LOTS=500

# =============================================================================
# EXIT THRESHOLDS
# =============================================================================

TAKE_PROFIT_PCT_OF_MAX_PROFIT=0.75
STOP_LOSS_PCT_OF_MAX_LOSS=1.5
THETA_BURN_LIMIT_INR_PER_DAY=2000
DELTA_HEDGE_THRESHOLD=0.30
VEGA_THRESHOLD=500.0

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO
